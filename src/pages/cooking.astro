---
import { Image } from "astro:assets";
import { cooking } from "../data/portfolio";
import Layout from "../layouts/Layout.astro";
import "../styles/cooking.css";

const featuredImages = cooking.images.filter(
  (image) => image.group === "featured",
);
const galleryImages = cooking.images.filter(
  (image) => image.group === "gallery",
);
const processImages = cooking.images.filter(
  (image) => image.group === "process",
);
---

<Layout
  title="Cooking"
  description="A cooking journal from Harman Kailey: bold flavors, rustic tools, process notes, and dishes made from scratch."
  bodyClass="cooking-page"
>
  <main id="main-content" class="page-main">
    <header class="cooking-hero">
      <div class="cooking-hero__copy">
        <p class="eyebrow">{cooking.eyebrow}</p>
        <h1>{cooking.title}</h1>
        <p>{cooking.summary}</p>
        <a class="text-link" href="#gallery"
          >Skip to the dishes <span aria-hidden="true">↓</span></a
        >
      </div>

      <div class="cooking-featured" role="group" aria-label="Featured dishes">
        {
          featuredImages.map((image, index) => (
            <figure class:list={[index === 0 && "cooking-featured__primary"]}>
              <Image
                src={image.src}
                alt={image.alt}
                width={index === 0 ? 1200 : 800}
                widths={index === 0 ? [480, 800, 1200] : [320, 560, 800]}
                sizes="(max-width: 720px) calc(100vw - 2rem), (max-width: 960px) 45vw, 28rem"
                layout="constrained"
                quality={80}
                format="webp"
                loading={index === 0 ? "eager" : "lazy"}
                fetchpriority={index === 0 ? "high" : "auto"}
              />
              <figcaption>{image.caption}</figcaption>
            </figure>
          ))
        }
      </div>
    </header>

    <section class="cooking-philosophy" aria-labelledby="philosophy-title">
      <div>
        <p class="eyebrow">Cooking philosophy</p>
        <h2 id="philosophy-title">Balance first. Boldness close behind.</h2>
        <p>{cooking.philosophy}</p>
      </div>
      <div class="cooking-themes">
        {
          cooking.themes.map((theme) => (
            <article>
              <h3>{theme.title}</h3>
              <p>{theme.text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section
      id="gallery"
      class="cooking-gallery"
      aria-labelledby="gallery-title"
    >
      <header class="section__heading">
        <p class="eyebrow">From the kitchen</p>
        <h2 id="gallery-title">Finished dishes and favorite experiments.</h2>
      </header>
      <div class="cooking-gallery__grid">
        {
          galleryImages.map((image, index) => (
            <figure class:list={[index === 0 && "cooking-gallery__wide"]}>
              <Image
                src={image.src}
                alt={image.alt}
                width={1000}
                widths={[360, 680, 1000]}
                sizes="(max-width: 720px) calc(100vw - 2rem), (max-width: 960px) 48vw, 25rem"
                layout="constrained"
                quality={78}
                format="webp"
                loading="lazy"
              />
              <figcaption>{image.caption}</figcaption>
            </figure>
          ))
        }
      </div>

      <details class="process-gallery">
        <summary
          >View {processImages.length} process notes from the kitchen</summary
        >
        <div class="process-gallery__grid">
          {
            processImages.map((image) => (
              <figure>
                <Image
                  src={image.src}
                  alt={image.alt}
                  width={800}
                  widths={[320, 560, 800]}
                  sizes="(max-width: 720px) calc(100vw - 2rem), (max-width: 960px) 48vw, 23rem"
                  layout="constrained"
                  quality={75}
                  format="webp"
                  loading="lazy"
                />
                <figcaption>{image.caption}</figcaption>
              </figure>
            ))
          }
        </div>
      </details>
    </section>

    <aside class="next-step next-step--cooking">
      <p class="eyebrow">Back to work</p>
      <h2>
        The cooking gets the color. The professional overview keeps the signal.
      </h2>
      <a class="button button--secondary" href="/">Return to the portfolio</a>
    </aside>
  </main>
</Layout>
