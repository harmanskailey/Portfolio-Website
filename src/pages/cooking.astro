---
import { Image } from "astro:assets";
import { cooking } from "../data/portfolio";
import Layout from "../layouts/Layout.astro";
import "../styles/cooking.css";

const featuredImages = cooking.images.filter(
  (image) => image.group === "featured",
);
const galleryImages = cooking.images.filter(
  (image) => image.group === "gallery",
);
const processImages = cooking.images.filter(
  (image) => image.group === "process",
);
---

<Layout
  title="Cooking"
  description="A cooking journal from Harman Kailey: bold flavors, rustic tools, process notes, and dishes made from scratch."
  bodyClass="cooking-page"
>
  <main id="main-content" class="page-main">
    <header class="cooking-hero">
      <div class="cooking-hero__copy">
        <p class="eyebrow">{cooking.eyebrow}</p>
        <h1>{cooking.title}</h1>
        <p>{cooking.summary}</p>
        <a class="text-link" href="#gallery"
          >Skip to the dishes <span aria-hidden="true">&darr;</span></a
        >
      </div>

      <div
        class="cooking-featured"
        role="region"
        aria-roledescription="carousel"
        aria-label="Featured dishes"
        data-cooking-carousel
      >
        <div class="cooking-featured__stage">
          {
            featuredImages.map((image, index) => (
              <figure
                class:list={[index === 0 && "is-active"]}
                aria-hidden={index === 0 ? "false" : "true"}
                data-cooking-slide
              >
                <Image
                  class="cooking-featured__backdrop"
                  src={image.src}
                  alt=""
                  aria-hidden="true"
                  width={800}
                  widths={[480, 800]}
                  sizes="(max-width: 960px) calc(100vw - 2rem), 40rem"
                  layout="constrained"
                  quality={62}
                  format="webp"
                  loading={index === 0 ? "eager" : "lazy"}
                />
                <Image
                  class="cooking-featured__image"
                  src={image.src}
                  alt={image.alt}
                  width={1200}
                  widths={[480, 800, 1200]}
                  sizes="(max-width: 960px) calc(100vw - 2rem), 40rem"
                  layout="constrained"
                  quality={82}
                  format="webp"
                  loading={index === 0 ? "eager" : "lazy"}
                  fetchpriority={index === 0 ? "high" : "auto"}
                />
              </figure>
            ))
          }
        </div>

        <div class="cooking-featured__controls">
          <div
            class="cooking-featured__selectors"
            aria-label="Choose a featured dish"
          >
            {
              featuredImages.map((_, index) => (
                <button
                  type="button"
                  class:list={[index === 0 && "is-active"]}
                  aria-label={`Show featured dish ${index + 1}`}
                  aria-pressed={index === 0 ? "true" : "false"}
                  data-cooking-selector={index}
                >
                  <span>{String(index + 1).padStart(2, "0")}</span>
                </button>
              ))
            }
          </div>
          <button
            type="button"
            class="cooking-featured__pause"
            aria-pressed="false"
            data-cooking-pause
          >
            Pause
          </button>
        </div>
        <p class="visually-hidden" aria-live="polite" data-cooking-status>
          Featured dish 1 of {featuredImages.length}
        </p>
      </div>
    </header>

    <section
      id="gallery"
      class="cooking-gallery"
      aria-labelledby="gallery-title"
    >
      <header class="section__heading">
        <p class="eyebrow">From the kitchen</p>
        <h2 id="gallery-title">Some highlights.</h2>
      </header>
      <div class="cooking-gallery__grid">
        {
          galleryImages.map((image, index) => (
            <figure class:list={[index === 0 && "cooking-gallery__wide"]}>
              <Image
                src={image.src}
                alt={image.alt}
                width={1000}
                widths={[360, 680, 1000]}
                sizes="(max-width: 720px) calc(100vw - 2rem), (max-width: 960px) 48vw, 25rem"
                layout="constrained"
                quality={78}
                format="webp"
                loading="lazy"
              />
            </figure>
          ))
        }
      </div>

      <details class="process-gallery">
        <summary
          >View {processImages.length} more images from the kitchen!</summary
        >
        <div class="process-gallery__grid">
          {
            processImages.map((image) => (
              <figure>
                <Image
                  src={image.src}
                  alt={image.alt}
                  width={800}
                  widths={[320, 560, 800]}
                  sizes="(max-width: 720px) calc(100vw - 2rem), (max-width: 960px) 48vw, 23rem"
                  layout="constrained"
                  quality={75}
                  format="webp"
                  loading="lazy"
                />
              </figure>
            ))
          }
        </div>
      </details>
    </section>

    <aside class="next-step next-step--cooking">
      <p class="eyebrow">Back to work</p>
      <h2>Mmm, that was delicious. Back to work!</h2>
      <a class="button button--secondary" href="/">Return to the portfolio</a>
    </aside>
  </main>
</Layout>

<script>
  const carousels = document.querySelectorAll<HTMLElement>(
    "[data-cooking-carousel]",
  );

  carousels.forEach((carousel) => {
    const slides = Array.from(
      carousel.querySelectorAll<HTMLElement>("[data-cooking-slide]"),
    );
    const selectors = Array.from(
      carousel.querySelectorAll<HTMLButtonElement>("[data-cooking-selector]"),
    );
    const pauseButton = carousel.querySelector<HTMLButtonElement>(
      "[data-cooking-pause]",
    );
    const status = carousel.querySelector<HTMLElement>("[data-cooking-status]");
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    let activeIndex = 0;
    let isPaused = reducedMotion;
    let timer: number | undefined;

    const showSlide = (nextIndex: number, announce = true) => {
      activeIndex = (nextIndex + slides.length) % slides.length;

      slides.forEach((slide, index) => {
        const active = index === activeIndex;
        slide.classList.toggle("is-active", active);
        slide.setAttribute("aria-hidden", String(!active));
      });

      selectors.forEach((selector, index) => {
        const active = index === activeIndex;
        selector.classList.toggle("is-active", active);
        selector.setAttribute("aria-pressed", String(active));
      });

      if (announce && status) {
        status.textContent = `Featured dish ${activeIndex + 1} of ${slides.length}`;
      }
    };

    const stopTimer = () => {
      if (timer !== undefined) window.clearInterval(timer);
      timer = undefined;
    };

    const startTimer = () => {
      stopTimer();
      if (!isPaused && slides.length > 1) {
        timer = window.setInterval(
          () => showSlide(activeIndex + 1, false),
          6000,
        );
      }
    };

    selectors.forEach((selector, index) => {
      selector.addEventListener("click", () => {
        showSlide(index);
        startTimer();
      });
    });

    pauseButton?.addEventListener("click", () => {
      isPaused = !isPaused;
      pauseButton.setAttribute("aria-pressed", String(isPaused));
      pauseButton.textContent = isPaused ? "Play" : "Pause";
      startTimer();
    });

    carousel.addEventListener("mouseenter", stopTimer);
    carousel.addEventListener("mouseleave", startTimer);
    carousel.addEventListener("focusin", stopTimer);
    carousel.addEventListener("focusout", (event) => {
      if (!carousel.contains(event.relatedTarget as Node | null)) startTimer();
    });

    if (reducedMotion && pauseButton) {
      pauseButton.textContent = "Play";
      pauseButton.setAttribute("aria-pressed", "true");
    }

    startTimer();
  });
</script>
