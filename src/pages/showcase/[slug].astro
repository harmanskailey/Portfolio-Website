---
export const prerender = false;

import { existsSync, readdirSync } from "node:fs";
import { join } from "node:path";
import { fileURLToPath } from "node:url";
import "../../styles/global.css";
import FireText from "../../components/FireText.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import WaterfallBackground from "../../components/WaterfallBackground.astro";
import profilePic from "../../assets/img/profile.jpeg";
import { homeSections } from "../../config/homeSections";
import { showcases, site } from "../../data/portfolio";
import type { ShowcaseImage } from "../../data/portfolio";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const homePath = `${basePath}/` || "/";
const { slug } = Astro.params;
const showcase = showcases.find((item) => item.slug === slug);

const supportedImageExtensions = new Set([
  ".jpg",
  ".jpeg",
  ".png",
  ".webp",
  ".avif",
  ".gif",
  ".svg",
]);

const rasterImageExtensions = new Set([
  ".jpg",
  ".jpeg",
  ".png",
  ".webp",
  ".avif",
  ".gif",
]);

const formatImageLabel = (value: string) =>
  value
    .replace(/\.[^.]+$/, "")
    .replace(/[-_]+/g, " ")
    .replace(/\s+/g, " ")
    .trim()
    .replace(/\b\w/g, (letter) => letter.toUpperCase());

const getFolderImages = (folderSlug: string): ShowcaseImage[] => {
  const imagesDirectory = fileURLToPath(new URL("../../../public/images", import.meta.url));
  const showcaseDirectory = join(imagesDirectory, folderSlug);

  if (!existsSync(showcaseDirectory)) {
    return [];
  }

  try {
    const imageNames = readdirSync(showcaseDirectory, { withFileTypes: true })
      .filter((entry) => entry.isFile())
      .map((entry) => entry.name)
      .filter((name) => {
        if (name.startsWith(".") || name.endsWith(".tmp") || name.endsWith(".crdownload")) {
          return false;
        }

        const extensionIndex = name.lastIndexOf(".");
        if (extensionIndex === -1) {
          return false;
        }

        const extension = name.slice(extensionIndex).toLowerCase();
        return supportedImageExtensions.has(extension);
      });

    const hasRasterImages = imageNames.some((name) => {
      const extension = name.slice(name.lastIndexOf(".")).toLowerCase();
      return rasterImageExtensions.has(extension);
    });

    return imageNames
      .filter((name) => {
        if (!hasRasterImages) {
          return true;
        }

        const extension = name.slice(name.lastIndexOf(".")).toLowerCase();
        return extension !== ".svg";
      })
      .sort((left, right) => left.localeCompare(right, undefined, { numeric: true }))
      .map((name) => {
        const label = formatImageLabel(name);
        return {
          src: `/images/${folderSlug}/${name}`,
          alt: `${showcase?.title ?? folderSlug} image: ${label}`,
          caption: label,
        };
      });
  } catch (error) {
    console.warn(`Unable to read showcase image folder for "${folderSlug}".`, error);
    return [];
  }
};

if (!showcase) {
  return Astro.redirect(homePath);
}

const galleryImages = showcase.images && showcase.images.length > 0
  ? showcase.images
  : getFolderImages(showcase.slug);
const featuredGallerySelections = showcase.featuredImageSources && showcase.featuredImageSources.length > 0
  ? showcase.featuredImageSources
      .map((src) => {
        const galleryIndex = galleryImages.findIndex((image) => image.src === src);
        return galleryIndex >= 0
          ? { image: galleryImages[galleryIndex], galleryIndex }
          : null;
      })
      .filter((entry): entry is { image: ShowcaseImage; galleryIndex: number } => Boolean(entry))
      .slice(0, 3)
  : galleryImages.slice(0, 3).map((image, galleryIndex) => ({ image, galleryIndex }));
const featuredGalleryData = featuredGallerySelections.map(({ image, galleryIndex }) => ({
  ...image,
  galleryIndex,
}));
const initialFeaturedHeroPosition = 0;

const pageTitle = `${showcase.title} | ${site.name}`;
const pageDescription = showcase.summary;
const previewImage = galleryImages[0]
  ? new URL(galleryImages[0].src, Astro.url).toString()
  : new URL(profilePic.src, Astro.url).toString();
const faviconVersion = "hk-2";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#0b1320" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta property="og:image" content={previewImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={previewImage} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${faviconVersion}`} />
    <link rel="shortcut icon" href={`/favicon.ico?v=${faviconVersion}`} />
    <link rel="apple-touch-icon" href={`/apple-touch-icon.png?v=${faviconVersion}`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <div class="page-shell" data-shell>
      <WaterfallBackground />

      <SiteHeader
        name={site.name}
        homePath={homePath}
        navItems={homeSections.map(({ id, label }) => ({ id, label }))}
      />

      <main class="page-content">
        <section class="detail-hero reveal is-visible">
          <div class="detail-hero__copy glass-panel spotlight-panel">
            <p class="eyebrow">{showcase.category}</p>
            <h1>{showcase.title}</h1>
            <p class="detail-hero__lede">{showcase.summary}</p>

            <div class="hero__actions">
              <a class="primary-button" href={homePath}>Back to portfolio</a>
              <a class="secondary-button" href="mailto:harmanskailey@gmail.com">Reach out</a>
            </div>
          </div>

          <aside class="detail-hero__panel glass-panel spotlight-panel">
            <p class="project-card__category">Focus</p>
            <ul class="detail-list">
              {showcase.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          </aside>
        </section>

        <section class="section-grid reveal is-visible">
          <article class="detail-headline glass-panel spotlight-panel">
            <p class="eyebrow">Cooking Philosophy</p>
            <h2>
              Balance and
              <FireText text="Boldness" className="detail-headline__fire" />
            </h2>
            <p>
              I have become obsessed with cooking from scratch. There
            </p>
          </article>
        </section>

        {(showcase.links && showcase.links.length > 0) || (showcase.resources && showcase.resources.length > 0) ? (
          <section class="section-grid reveal is-visible">
            <div class="detail-grid">
              {showcase.links && showcase.links.length > 0 && (
                <article class="feature-card glass-panel spotlight-panel">
                  <p class="eyebrow">Links</p>
                  <h3>External references</h3>
                  <div class="link-list">
                    {showcase.links.map((link) => (
                      <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
                        {link.label}
                      </a>
                    ))}
                  </div>
                </article>
              )}

              {showcase.resources && showcase.resources.length > 0 && (
                <article class="feature-card glass-panel spotlight-panel">
                  <p class="eyebrow">Resources</p>
                  <h3>Files and hosted work</h3>
                  <div class="resource-list">
                    {showcase.resources.map((resource) => (
                      <a
                        class="resource-card"
                        href={resource.href}
                        target={resource.href.startsWith("http") ? "_blank" : undefined}
                        rel="noreferrer"
                      >
                        <div>
                          <p class="resource-card__kind">{resource.kind}</p>
                          <strong>{resource.label}</strong>
                        </div>
                        {resource.description && <span>{resource.description}</span>}
                      </a>
                    ))}
                  </div>
                </article>
              )}
            </div>
          </section>
        ) : null}

        {galleryImages.length > 0 && (
          <section class="section-grid reveal is-visible">
            <div class="section-heading">
              <p class="eyebrow">Gallery</p>
              <h2>Some Cooking Highlights</h2>
            </div>

            <div class="featured-gallery">
              {featuredGallerySelections.map(({ image, galleryIndex }, index) => (
                <button
                  type="button"
                  class:list={["featured-gallery__card", index === 0 && "featured-gallery__card--hero", "glass-panel", "spotlight-panel"]}
                  data-featured-image={galleryIndex}
                  data-featured-role={index === 0 ? "hero" : "secondary"}
                  aria-label={
                    index === 0
                      ? `Primary highlight: ${image.caption ?? image.alt}`
                      : `Show ${image.caption ?? image.alt} as the main highlight`
                  }
                >
                  <img
                    src={image.src}
                    alt={image.alt}
                    class="featured-gallery__image"
                    loading={index === 0 ? "eager" : "lazy"}
                    decoding="async"
                    fetchpriority={index === 0 ? "high" : "auto"}
                  />
                  {(image.caption || image.alt) && (
                    <span class="featured-gallery__caption">
                      {image.caption ?? image.alt}
                    </span>
                  )}
                </button>
              ))}
            </div>

            {galleryImages.length > featuredGallerySelections.length && (
              <div class="gallery-expand glass-panel spotlight-panel" data-gallery-expand>
                <div class="gallery-expand__content">
                  <p class="eyebrow">More images</p>
                  <h3>Open the full slideshow.</h3>
                  <p>
                    Browse the rest of the gallery without crowding the page on first load.
                  </p>
                </div>

                <button type="button" class="primary-button gallery-expand__button" data-gallery-toggle aria-expanded="false">
                  View more
                </button>
              </div>
            )}

            <div class="slideshow glass-panel spotlight-panel" data-slideshow hidden={galleryImages.length > featuredGallerySelections.length ? true : undefined}>
              <div class="slideshow__viewport">
                {galleryImages.map((image, index) => (
                  <figure
                    class:list={["slideshow__slide", index === 0 && "is-active"]}
                    data-slide
                    aria-hidden={index === 0 ? "false" : "true"}
                  >
                    <img
                      src={image.src}
                      alt={image.alt}
                      class="slideshow__image"
                      loading={index === 0 ? "eager" : "lazy"}
                      decoding="async"
                      fetchpriority={index === 0 ? "high" : "auto"}
                      data-image
                    />
                    {(image.caption || image.alt) && (
                      <figcaption class="slideshow__caption">
                        {image.caption ?? image.alt}
                      </figcaption>
                    )}
                  </figure>
                ))}
              </div>

              {galleryImages.length > 1 && (
                <>
                  <button type="button" class="slideshow__control slideshow__control--prev" data-prev aria-label="Previous image">
                    Prev
                  </button>
                  <button type="button" class="slideshow__control slideshow__control--next" data-next aria-label="Next image">
                    Next
                  </button>

                  <div class="slideshow__dots" aria-label="Choose slide">
                    {galleryImages.map((image, index) => (
                      <button
                        type="button"
                        class:list={["slideshow__dot", index === 0 && "is-active"]}
                        data-dot={index}
                        aria-label={`Show image ${index + 1}: ${image.alt}`}
                        aria-pressed={index === 0 ? "true" : "false"}
                      />
                    ))}
                  </div>
                </>
              )}
            </div>
          </section>
        )}
      </main>
    </div>

    <script
      is:inline
      define:vars={{
        galleryImageData: galleryImages,
        featuredImageData: featuredGalleryData,
        initialFeaturedHeroPosition,
      }}
    >
      const initializeSlideshow = (slideshow) => {
        if (!slideshow || slideshow.dataset.initialized === "true") return;

        slideshow.dataset.initialized = "true";
        const slides = Array.from(slideshow.querySelectorAll("[data-slide]"));
        const dots = Array.from(slideshow.querySelectorAll("[data-dot]"));
        const prevButton = slideshow.querySelector("[data-prev]");
        const nextButton = slideshow.querySelector("[data-next]");
        const images = Array.from(slideshow.querySelectorAll("[data-image]"));

        if (slides.length <= 1) return;

        let activeIndex = 0;

        const warmImage = (index) => {
          const normalizedIndex = (index + images.length) % images.length;
          const image = images[normalizedIndex];

          if (!image || image.dataset.warmed === "true") return;

          image.loading = "eager";
          image.dataset.warmed = "true";
        };

        const render = (nextIndex) => {
          activeIndex = (nextIndex + slides.length) % slides.length;

          slides.forEach((slide, index) => {
            const isActive = index === activeIndex;
            slide.classList.toggle("is-active", isActive);
            slide.setAttribute("aria-hidden", String(!isActive));
          });

          dots.forEach((dot, index) => {
            const isActive = index === activeIndex;
            dot.classList.toggle("is-active", isActive);
            dot.setAttribute("aria-pressed", String(isActive));
          });

          warmImage(activeIndex);
          warmImage(activeIndex + 1);
        };

        slideshow.goToSlide = render;

        warmImage(0);
        warmImage(1);

        prevButton?.addEventListener("click", () => render(activeIndex - 1));
        nextButton?.addEventListener("click", () => render(activeIndex + 1));

        dots.forEach((dot, index) => {
          dot.addEventListener("click", () => render(index));
        });
      };

      const slideshows = document.querySelectorAll("[data-slideshow]");
      slideshows.forEach((slideshow) => {
        if (!slideshow.hasAttribute("hidden")) {
          initializeSlideshow(slideshow);
        }
      });

      const galleryExpansions = document.querySelectorAll("[data-gallery-expand]");
      galleryExpansions.forEach((expansion) => {
        const button = expansion.querySelector("[data-gallery-toggle]");
        const slideshow = expansion.parentElement?.querySelector("[data-slideshow]");

        if (!button || !slideshow) return;

        button.addEventListener("click", () => {
          const isExpanded = button.getAttribute("aria-expanded") === "true";
          const nextExpanded = !isExpanded;

          button.setAttribute("aria-expanded", String(nextExpanded));
          button.textContent = nextExpanded ? "Hide gallery" : "View more";
          slideshow.hidden = !nextExpanded;

          if (nextExpanded) {
            initializeSlideshow(slideshow);
            slideshow.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        });
      });

      const featuredImages = document.querySelectorAll("[data-featured-image]");
      const featuredGallery = document.querySelector(".featured-gallery");
      const featuredHero = featuredGallery?.querySelector('[data-featured-role="hero"]');
      const featuredSecondaryCards = Array.from(featuredGallery?.querySelectorAll('[data-featured-role="secondary"]') ?? []);

      const updateFeaturedCard = (card, image, galleryIndex, role) => {
        if (!card || !image) return;

        const imageElement = card.querySelector("img");
        const captionElement = card.querySelector(".featured-gallery__caption");
        const label = image.caption ?? image.alt;

        card.setAttribute("data-featured-image", String(galleryIndex));
        card.setAttribute(
          "aria-label",
          role === "hero"
            ? `Primary highlight: ${label}`
            : `Show ${label} as the main highlight`
        );

        if (imageElement) {
          imageElement.src = image.src;
          imageElement.alt = image.alt;
        }

        if (captionElement) {
          captionElement.textContent = label;
        }
      };

      let featuredActivePosition = initialFeaturedHeroPosition;

      const renderFeaturedGallery = () => {
        if (!featuredImageData.length || !featuredGallery) return;

        const secondaryImages = featuredImageData.filter((_, index) => index !== featuredActivePosition);

        updateFeaturedCard(
          featuredHero,
          featuredImageData[featuredActivePosition],
          featuredImageData[featuredActivePosition].galleryIndex,
          "hero"
        );

        featuredSecondaryCards.forEach((card, index) => {
          const image = secondaryImages[index];
          if (!image) return;

          updateFeaturedCard(card, image, image.galleryIndex, "secondary");
        });
      };

      renderFeaturedGallery();

      featuredImages.forEach((featuredImage) => {
        featuredImage.addEventListener("click", () => {
          const requestedIndex = Number(featuredImage.getAttribute("data-featured-image"));
          const requestedPosition = featuredImageData.findIndex((image) => image.galleryIndex === requestedIndex);

          if (requestedPosition === -1) return;

          featuredActivePosition = requestedPosition;
          renderFeaturedGallery();
        });
      });
    </script>
  </body>
</html>
