---
import { sanitizeRedirect } from "../lib/auth";
import { site } from "../data/portfolio";

export const prerender = false;

const redirectTo = sanitizeRedirect(
  Astro.url.searchParams.get("redirect"),
  Astro.url.origin,
);
const hasError = Astro.url.searchParams.get("error") === "invalid";
const wasLocked = Astro.url.searchParams.get("message") === "locked";
const describedBy = hasError ? "passcode-help passcode-error" : "passcode-help";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={`Private access to ${site.name}'s professional portfolio.`}
    />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="referrer" content="no-referrer" />
    <meta name="theme-color" content="#f4f2ec" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 64 64%22><rect width=%2264%22 height=%2264%22 rx=%2232%22 fill=%22%2317221f%22/><text x=%2232%22 y=%2239%22 text-anchor=%22middle%22 font-family=%22Arial%22 font-size=%2220%22 font-weight=%22700%22 fill=%22white%22>HK</text></svg>"
    />
    <title>Private Portfolio | {site.name}</title>
    <style is:inline>
      :root {
        color-scheme: light;
        --paper: #f4f2ec;
        --surface: #fffdf8;
        --ink: #17221f;
        --muted: #5e6864;
        --line: rgba(23, 34, 31, 0.16);
        --accent: #a6452c;
        --accent-dark: #71301f;
        --forest: #173f35;
        --focus: #176fbd;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        min-width: 20rem;
        background: var(--paper);
      }

      body {
        min-height: 100svh;
        margin: 0;
        background:
          radial-gradient(
            circle at 88% 5%,
            rgba(166, 69, 44, 0.15),
            transparent 24rem
          ),
          linear-gradient(180deg, #f7f5ef 0%, var(--paper) 32rem);
        color: var(--ink);
        font-family: "Segoe UI", system-ui, sans-serif;
        line-height: 1.6;
      }

      button,
      input {
        font: inherit;
      }

      :focus-visible {
        outline: 3px solid var(--focus);
        outline-offset: 3px;
        box-shadow: 0 0 0 6px rgba(255, 253, 248, 0.96);
      }

      .shell {
        display: grid;
        width: min(100% - 3rem, 74rem);
        min-height: 100svh;
        margin-inline: auto;
        grid-template-rows: auto 1fr auto;
      }

      .brand {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        gap: 0.75rem;
        padding-block: 1.4rem;
        color: var(--ink);
        font-weight: 700;
        text-decoration: none;
      }

      .brand__mark {
        display: grid;
        width: 2.45rem;
        height: 2.45rem;
        place-items: center;
        border-radius: 50%;
        background: var(--ink);
        color: var(--surface);
        font-size: 0.75rem;
        letter-spacing: 0.08em;
      }

      main {
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(19rem, 0.65fr);
        gap: clamp(3rem, 8vw, 7rem);
        align-items: center;
        padding-block: clamp(3rem, 8vw, 7rem);
      }

      .eyebrow,
      .status {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.13em;
        text-transform: uppercase;
      }

      .eyebrow {
        margin: 0;
        color: var(--accent);
      }

      h1,
      h2,
      p {
        margin: 0;
      }

      h1,
      h2 {
        font-family: Georgia, "Times New Roman", serif;
        text-wrap: balance;
      }

      h1 {
        max-width: 12ch;
        margin-top: 1rem;
        font-size: clamp(3rem, 6.8vw, 6.4rem);
        font-weight: 600;
        letter-spacing: -0.045em;
        line-height: 0.95;
      }

      .intro {
        max-width: 43rem;
        margin-top: 1.5rem;
        color: var(--muted);
        font-size: clamp(1.05rem, 1.8vw, 1.22rem);
      }

      .access-card {
        padding: clamp(1.5rem, 4vw, 2.25rem);
        border: 1px solid var(--line);
        border-radius: 1.5rem;
        background: rgba(255, 253, 248, 0.9);
        box-shadow: 0 1.2rem 3.6rem rgba(29, 39, 35, 0.11);
        backdrop-filter: blur(16px);
      }

      .status {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.42rem 0.65rem;
        border-radius: 999px;
        background: #dce6df;
        color: var(--forest);
      }

      .status::before {
        width: 0.45rem;
        height: 0.45rem;
        border-radius: 50%;
        background: currentColor;
        content: "";
      }

      .access-card h2 {
        margin-top: 1.35rem;
        font-size: clamp(1.8rem, 4vw, 2.5rem);
        letter-spacing: -0.03em;
        line-height: 1;
      }

      form {
        margin-top: 1.6rem;
      }

      label {
        display: block;
        font-size: 0.88rem;
        font-weight: 700;
      }

      .field {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        margin-top: 0.45rem;
        overflow: hidden;
        border: 1px solid rgba(23, 34, 31, 0.32);
        border-radius: 0.8rem;
        background: white;
      }

      .field:focus-within {
        outline: 3px solid var(--focus);
        outline-offset: 2px;
      }

      .field input {
        width: 100%;
        min-height: 3.2rem;
        padding: 0.75rem 0.9rem;
        border: 0;
        outline: 0;
        background: transparent;
        color: var(--ink);
      }

      .field button {
        min-width: 4.5rem;
        border: 0;
        border-left: 1px solid var(--line);
        background: #ece9e0;
        color: var(--ink);
        cursor: pointer;
        font-size: 0.8rem;
        font-weight: 700;
      }

      .field button:focus-visible {
        outline-offset: -4px;
        box-shadow: none;
      }

      .help,
      .error,
      .locked,
      .contact,
      footer {
        font-size: 0.82rem;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .help {
        margin-top: 0.5rem;
        color: var(--muted);
      }

      .error,
      .locked {
        margin-bottom: 1rem;
        padding: 0.7rem 0.8rem;
        border-radius: 0.65rem;
      }

      .error {
        background: #f6dfd7;
        color: #6e2819;
        font-weight: 700;
      }

      .locked {
        background: #dce6df;
        color: var(--forest);
      }

      .submit {
        width: 100%;
        min-height: 3.1rem;
        margin-top: 1.25rem;
        padding: 0.75rem 1rem;
        border: 0;
        border-radius: 999px;
        background: var(--ink);
        color: white;
        cursor: pointer;
        font-weight: 700;
        transition:
          background-color 180ms ease,
          transform 180ms ease;
      }

      .submit:hover:not(:disabled) {
        background: var(--forest);
        transform: translateY(-2px);
      }

      .submit:disabled {
        cursor: wait;
        opacity: 0.75;
      }

      .contact {
        margin-top: 1.15rem;
        color: var(--muted);
        text-align: center;
      }

      .contact a {
        color: var(--accent-dark);
        font-weight: 700;
        text-underline-offset: 0.2em;
      }

      footer {
        padding-block: 1.5rem 2rem;
        border-top: 1px solid var(--line);
        color: var(--muted);
      }

      @media (max-width: 760px) {
        .shell {
          width: min(100% - 2rem, 42rem);
        }

        main {
          grid-template-columns: 1fr;
          gap: 2rem;
          padding-block: 2rem 3.5rem;
        }

        h1 {
          font-size: clamp(2.65rem, 11vw, 3.8rem);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <a class="brand" href="/login" aria-label={`${site.name}, access page`}>
        <span class="brand__mark" aria-hidden="true">HK</span>
        <span>{site.name}</span>
      </a>

      <main>
        <section aria-labelledby="access-heading">
          <p class="eyebrow">Private preview</p>
          <h1 id="access-heading">Where's your hall pass?</h1>
          <p class="intro">
            Be gone data scraping bots. Anyways, hopefully you're supposed to be
            here. It's a work in progress inside, but a much better take on a
            portfolio site. The cooking section might become my personal journal
            for my recipes.
          </p>
        </section>

        <section class="access-card" aria-labelledby="form-heading">
          <p class="status">
            {wasLocked ? "Portfolio locked" : "Passcode required"}
          </p>
          <h2 id="form-heading">Credentials, please.</h2>

          <form method="post" action="/api/login" data-login-form>
            <input type="hidden" name="redirect" value={redirectTo} />
            {
              hasError && (
                <p class="error" id="passcode-error" role="alert">
                  That passcode didn't pass code review. Check it and try again.
                </p>
              )
            }
            {
              wasLocked && !hasError && (
                <p class="locked" role="status">
                  Portfolio re-locked. The cooking section is contained again.
                </p>
              )
            }

            <label for="passcode">Portfolio passcode</label>
            <div class="field">
              <input
                id="passcode"
                name="passcode"
                type="password"
                autocomplete="current-password"
                autocapitalize="none"
                spellcheck="false"
                maxlength="256"
                aria-invalid={hasError ? "true" : undefined}
                aria-describedby={describedBy}
                required
              />
              <button
                type="button"
                data-toggle-passcode
                aria-controls="passcode"
                aria-label="Show passcode"
                aria-pressed="false">Show</button
              >
            </div>
            <p class="help" id="passcode-help">
              Use the passcode Harman shared with you.
            </p>

            <button class="submit" type="submit" data-submit>
              Unlock the portfolio
            </button>
            <p
              class="visually-hidden"
              role="status"
              aria-live="polite"
              data-form-status
            >
            </p>
          </form>

          <p class="contact">
            No passcode? <a href={`mailto:${site.email}`}>Email Harman.</a>
          </p>
        </section>
      </main>

      <footer>Comment like and subscribe thanks.</footer>
    </div>

    <script is:inline>
      const input = document.querySelector("#passcode");
      const toggle = document.querySelector("[data-toggle-passcode]");
      const form = document.querySelector("[data-login-form]");
      const submit = document.querySelector("[data-submit]");
      const formStatus = document.querySelector("[data-form-status]");

      toggle?.addEventListener("click", () => {
        if (!(input instanceof HTMLInputElement)) return;

        const revealing = input.type === "password";
        input.type = revealing ? "text" : "password";
        toggle.textContent = revealing ? "Hide" : "Show";
        toggle.setAttribute(
          "aria-label",
          revealing ? "Hide passcode" : "Show passcode",
        );
        toggle.setAttribute("aria-pressed", String(revealing));
      });

      form?.addEventListener("submit", () => {
        if (!(submit instanceof HTMLButtonElement)) return;
        form.setAttribute("aria-busy", "true");
        submit.disabled = true;
        submit.textContent = "Checking the guest list...";
        if (formStatus) formStatus.textContent = "Checking the guest list.";
      });

      if (document.querySelector("[role='alert']")) {
        input?.focus();
        if (input instanceof HTMLInputElement) input.select();
      }
    </script>
  </body>
</html>
