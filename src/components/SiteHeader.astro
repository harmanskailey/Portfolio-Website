---
type Props = {
  name: string;
  logoutAction: string;
  homePath?: string;
};

const { name, logoutAction, homePath = "/" } = Astro.props;
---

<header class="topbar">
  <a href={`${homePath}#hero`} class="brand-mark">
    <span class="brand-mark__monogram" aria-hidden="true">HK</span>
    <span>{name}</span>
  </a>

  <nav class="topbar__nav" aria-label="Section navigation">
    <a href={`${homePath}#about`}>About</a>
    <a href={`${homePath}#experience`}>Experience</a>
    <a href={`${homePath}#projects`}>Projects</a>
    <a href={`${homePath}#showcase`}>Showcase</a>
    <a href={`${homePath}#contact`}>Contact</a>
  </nav>

  <form method="POST" action={logoutAction}>
    <button type="submit" class="ghost-button">Sign out</button>
  </form>
</header>
