---
import { site } from "../data/portfolio";

const normalizePath = (path: string) =>
  path === "/" ? path : path.replace(/\/+$/, "");
const currentPath = normalizePath(Astro.url.pathname);
const navItems = [
  { label: "Experience", href: "/#experience" },
  { label: "Projects", href: "/#projects" },
  { label: "Background", href: "/#background" },
  { label: "Cooking", href: "/cooking" },
  { label: "Contact", href: "/#contact" },
];
---

<header class="site-header">
  <a href="/" class="brand" aria-label={`${site.name}, home`}>
    <span class="brand__mark" aria-hidden="true">HK</span>
    <span class="brand__name">{site.name}</span>
  </a>

  <nav class="site-nav" aria-label="Primary navigation">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          aria-current={
            !item.href.includes("#") && currentPath === normalizePath(item.href)
              ? "page"
              : undefined
          }
        >
          {item.label}
        </a>
      ))
    }
    <form class="site-nav__lock" method="post" action="/api/logout">
      <button type="submit">Lock site</button>
    </form>
  </nav>
</header>
