---
type NavItem = {
  id: string;
  label: string;
};

type Props = {
  name: string;
  homePath?: string;
  navItems?: NavItem[];
};

const {
  name,
  homePath = "/",
  navItems = [],
} = Astro.props;
---

<header class="topbar">
  <a href={`${homePath}#hero`} class="brand-mark">
    <span class="brand-mark__monogram" aria-hidden="true">HK</span>
    <span>{name}</span>
  </a>

  <nav class="topbar__nav" aria-label="Section navigation">
    {navItems.map((item) => (
      <a href={`${homePath}#${item.id}`}>{item.label}</a>
    ))}
  </nav>
</header>
