---
import { Image } from "astro:assets";
import type { CookingContent } from "../data/portfolio";

type Props = {
  content: CookingContent;
};

const { content } = Astro.props;
const image =
  content.images.find((item) => item.group === "featured") ?? content.images[0];
---

<section
  id="personal"
  class="cooking-teaser"
  aria-labelledby="cooking-teaser-title"
>
  <div class="cooking-teaser__copy">
    <p class="eyebrow">Personal archive</p>
    <h2 id="cooking-teaser-title">Work is only one part of the story.</h2>
    <p>
      The personal side starts with a cooking journal and will grow to include
      Cooper, recipes, and the quieter projects that do not belong on a resume.
    </p>
    <a class="button button--secondary" href="/cooking"
      >Explore the cooking journal</a
    >
    <p class="personal-roadmap">
      <span>Next collection</span>
      Cooper &middot; walks, field notes, and an unreasonable number of photos
    </p>
  </div>
  <figure>
    <Image
      src={image.src}
      alt={image.alt}
      width={900}
      widths={[400, 650, 900]}
      sizes="(max-width: 960px) calc(100vw - 5rem), 34rem"
      layout="constrained"
      quality={78}
      format="webp"
      loading="lazy"
    />
  </figure>
</section>
