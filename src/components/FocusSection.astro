---
import type { FocusArea } from "../data/portfolio";

type Props = {
  items: FocusArea[];
};

const { items } = Astro.props;
---

<section class="focus-section" aria-labelledby="focus-title">
  <header class="focus-section__intro">
    <p class="eyebrow">Three paths</p>
  </header>

  <div class="focus-grid">
    {
      items.map((item, index) => (
        <article class:list={["focus-card", `focus-card--${item.slug}`]}>
          <p class="focus-card__number">{String(index + 1).padStart(2, "0")}</p>
          <p class="focus-card__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          <ul>
            {item.details.map((detail) => (
              <li>{detail}</li>
            ))}
          </ul>
          <a class="text-link" href={item.href}>
            Enter {item.kicker} <span aria-hidden="true">&rarr;</span>
          </a>
        </article>
      ))
    }
  </div>
</section>
