---
import type { ResearchDirection } from "../data/portfolio";
import SectionShell from "./SectionShell.astro";

type Props = {
  items: ResearchDirection[];
};

const { items } = Astro.props;
---

<SectionShell
  id="research-agenda"
  eyebrow="Research direction"
  heading="The questions I want the next reports to answer."
  intro="This is a working agenda rather than a claim of finished expertise. It gives future coursework, independent studies, and R deployments a clear place to land."
  className="research-agenda"
>
  <div class="agenda-grid">
    {
      items.map((item) => (
        <article class="agenda-card">
          <p class="agenda-card__stage">{item.stage}</p>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          <ul>
            {item.questions.map((question) => (
              <li>{question}</li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</SectionShell>
