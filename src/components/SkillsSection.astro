---
import type { SkillsContent } from "../data/portfolio";
import SectionShell from "./SectionShell.astro";

type Props = {
  id?: string;
  eyebrow?: string;
  heading?: string;
  skills: SkillsContent;
};

const {
  id = "skills",
  eyebrow = "Skills",
  heading = "Core tools and systems I work with most often.",
  skills,
} = Astro.props;
---

<SectionShell id={id} eyebrow={eyebrow} heading={heading}>
  <div class="skill-layout">
    <article class="glass-panel spotlight-panel skill-panel">
      <h3>Software stack</h3>
      <div class="chip-row">
        {skills.stack.map((skill) => (
          <span class="chip">{skill}</span>
        ))}
      </div>
    </article>

    <article class="glass-panel spotlight-panel skill-panel">
      <h3>Hardware and systems</h3>
      <div class="chip-row">
        {skills.hardware.map((skill) => (
          <span class="chip chip-soft">{skill}</span>
        ))}
      </div>
    </article>
  </div>
</SectionShell>
