---
import { Image } from "astro:assets";
import profilePic from "../assets/img/profile.jpeg";
import type { ImpactItem, SiteContent } from "../data/portfolio";

type Props = {
  site: SiteContent;
  impactItems: ImpactItem[];
};

const { site, impactItems } = Astro.props;
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__copy">
    <p class="eyebrow">{site.eyebrow}</p>
    <h1 id="hero-title">{site.headline}</h1>
    <p class="hero__intro">{site.intro}</p>
    <div class="button-row">
      <a class="button button--primary" href="#experience">Explore my work</a>
      <a class="button button--secondary" href={`mailto:${site.email}`}
        >Get in touch</a
      >
    </div>
    <p class="hero__location">
      {site.location} · Applied Statistics M.S. candidate
    </p>
  </div>

  <figure class="portrait">
    <Image
      src={profilePic}
      alt={`${site.name} kneeling beside his dog on a sunlit balcony`}
      width={720}
      widths={[360, 540, 720]}
      sizes="(max-width: 720px) calc(100vw - 2rem), (max-width: 960px) 30rem, 22rem"
      layout="constrained"
      quality={82}
      format="webp"
      loading="eager"
      fetchpriority="high"
    />
    <figcaption>
      <span>{site.name}</span>
      <span>Software engineer</span>
    </figcaption>
  </figure>

  <dl class="impact-strip" aria-label="Selected impact">
    {
      impactItems.map((item) => (
        <div class="impact-item">
          <dt>
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </dt>
          <dd>{item.description}</dd>
        </div>
      ))
    }
  </dl>
</section>
