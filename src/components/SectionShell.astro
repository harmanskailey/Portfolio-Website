---
type Props = {
  id: string;
  eyebrow: string;
  heading: string;
  className?: string;
};

const { id, eyebrow, heading, className } = Astro.props;
---

<section id={id} class:list={["section-grid", "reveal", className]}>
  <div class="section-heading">
    <p class="eyebrow">{eyebrow}</p>
    <h2>{heading}</h2>
  </div>

  <slot />
</section>
