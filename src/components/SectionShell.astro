---
type Props = {
  id: string;
  eyebrow: string;
  heading: string;
  className?: string;
  stageLabel?: string;
};

const { id, eyebrow, heading, className, stageLabel } = Astro.props;
---

<section id={id} class:list={["section-grid", "reveal", className]} data-scroll-section>
  <div class="section-heading">
    <div class="section-kicker">
      {stageLabel && <span class="section-stage">{stageLabel}</span>}
      <p class="eyebrow">{eyebrow}</p>
    </div>
    <h2>{heading}</h2>
  </div>

  <slot />
</section>
