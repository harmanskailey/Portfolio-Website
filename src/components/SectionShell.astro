---
type Props = {
  id: string;
  eyebrow: string;
  heading: string;
  intro?: string;
  className?: string;
};

const { id, eyebrow, heading, intro, className } = Astro.props;
---

<section id={id} class:list={["section", className]}>
  <header class="section__heading">
    <p class="eyebrow">{eyebrow}</p>
    <h2>{heading}</h2>
    {intro && <p class="section__intro">{intro}</p>}
  </header>
  <slot />
</section>
