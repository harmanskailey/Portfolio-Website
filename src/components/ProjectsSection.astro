---
import type { ProjectItem } from "../data/portfolio";
import SectionShell from "./SectionShell.astro";

type Props = {
  id?: string;
  eyebrow?: string;
  heading?: string;
  projects: ProjectItem[];
};

const {
  id = "projects",
  eyebrow = "Projects",
  heading = "Selected projects across software, hardware, and applied experimentation.",
  projects,
} = Astro.props;
---

<SectionShell id={id} eyebrow={eyebrow} heading={heading}>
  <div class="project-grid">
    {projects.map((project) => (
      <article class="project-card glass-panel spotlight-panel">
        <p class="project-card__category">{project.category}</p>
        <h3>{project.title}</h3>
        <p>{project.description}</p>
        <div class="chip-row">
          {project.tags.map((tag) => (
            <span class="chip">{tag}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
</SectionShell>
