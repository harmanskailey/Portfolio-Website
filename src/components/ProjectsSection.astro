---
import type { ProjectItem } from "../data/portfolio";

type Props = {
  projects: ProjectItem[];
};

const { projects } = Astro.props;
---

<section class="section-grid reveal" id="projects">
  <div class="section-heading">
    <p class="eyebrow">Projects</p>
    <h2>Selected builds presented as modular cards you can keep extending.</h2>
  </div>

  <div class="project-grid">
    {projects.map((project) => (
      <article class="project-card glass-panel spotlight-panel">
        <p class="project-card__category">{project.category}</p>
        <h3>{project.title}</h3>
        <p>{project.description}</p>
        <div class="chip-row">
          {project.tags.map((tag) => (
            <span class="chip">{tag}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>
