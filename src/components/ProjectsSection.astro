---
import type { WorkItem } from "../data/portfolio";
import SectionShell from "./SectionShell.astro";

type Props = {
  items: WorkItem[];
};

const { items } = Astro.props;
---

<SectionShell
  id="projects"
  eyebrow="Selected projects"
  heading="Statistics, visualization, and the infrastructure behind this site."
  intro="A small set of projects with enough substance to explain the question, method, and delivery."
>
  <div class="project-grid">
    {
      items.map((item) => (
        <article
          class:list={[
            "project-card",
            item.featured && "project-card--featured",
          ]}
        >
          <p class="project-card__period">{item.period}</p>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          <ul class="compact-list">
            {item.highlights.map((highlight) => (
              <li>{highlight}</li>
            ))}
          </ul>
          <div class="chip-list">
            {item.skills.map((skill) => (
              <span>{skill}</span>
            ))}
          </div>
          <div class="project-card__actions">
            <a class="text-link" href={`/work/${item.slug}`}>
              Read the {item.title} case study <span aria-hidden="true">→</span>
            </a>
            {item.links?.map((link) => (
              <a
                class="text-link text-link--muted"
                href={link.href}
                target="_blank"
                rel="noreferrer"
              >
                {link.label} <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</SectionShell>
