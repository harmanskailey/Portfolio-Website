---
import type { EducationItem } from "../data/portfolio";
import SectionShell from "./SectionShell.astro";

type Props = {
  id?: string;
  eyebrow?: string;
  heading?: string;
  stageLabel?: string;
  items: EducationItem[];
};

const {
  id = "education",
  eyebrow = "Education",
  heading = "Coursework and study that sharpen how I frame technical problems.",
  stageLabel,
  items,
} = Astro.props;
---

<SectionShell id={id} eyebrow={eyebrow} heading={heading} stageLabel={stageLabel}>
  <div class="timeline education-timeline">
    {items.map((item) => (
      <article class="timeline-card education-card glass-panel spotlight-panel">
        <div class="timeline-card__meta">
          <p>{item.school}</p>
          <span>{item.period}</span>
        </div>
        <h3>{item.degree}</h3>
        <p>{item.summary}</p>
        <details class="story-disclosure">
          <summary>See focus areas</summary>
          <ul class="detail-list">
            {item.details.map((detail) => (
              <li>{detail}</li>
            ))}
          </ul>
        </details>
      </article>
    ))}
  </div>
</SectionShell>
