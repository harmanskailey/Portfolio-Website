---
import type { LinkItem } from "../data/portfolio";
import SectionShell from "./SectionShell.astro";

type Props = {
  id?: string;
  eyebrow?: string;
  heading?: string;
  interests: string[];
  socialLinks: LinkItem[];
};

const {
  id = "contact",
  eyebrow = "Contact",
  heading = "Interests, links, and the easiest ways to reach me.",
  interests,
  socialLinks,
} = Astro.props;
---

<SectionShell id={id} eyebrow={eyebrow} heading={heading}>
  <div class="contact-layout">
    <article class="glass-panel spotlight-panel contact-card">
      <h3>Interests</h3>
      <div class="chip-row">
        {interests.map((interest) => (
          <span class="chip chip-soft">{interest}</span>
        ))}
      </div>
    </article>

    <article class="glass-panel spotlight-panel contact-card">
      <h3>Connect</h3>
      <p>I am easiest to reach by email or LinkedIn, and I keep code samples on GitHub.</p>
      <div class="link-list">
        {socialLinks.map((link) => (
          <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
            {link.label}
          </a>
        ))}
      </div>
    </article>
  </div>
</SectionShell>
