---
import type { LinkItem } from "../data/portfolio";

type Props = {
  interests: string[];
  socialLinks: LinkItem[];
};

const { interests, socialLinks } = Astro.props;
---

<section class="section-grid reveal" id="contact">
  <div class="section-heading">
    <p class="eyebrow">Contact</p>
    <h2>Interests, links, and the easiest ways to reach me.</h2>
  </div>

  <div class="contact-layout">
    <article class="glass-panel spotlight-panel contact-card">
      <h3>Interests</h3>
      <div class="chip-row">
        {interests.map((interest) => (
          <span class="chip chip-soft">{interest}</span>
        ))}
      </div>
    </article>

    <article class="glass-panel spotlight-panel contact-card">
      <h3>Connect</h3>
      <p>I am easiest to reach by email or LinkedIn, and I keep code samples on GitHub.</p>
      <div class="link-list">
        {socialLinks.map((link) => (
          <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
            {link.label}
          </a>
        ))}
      </div>
    </article>
  </div>
</section>
