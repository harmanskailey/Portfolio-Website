---
import type { ExperienceItem } from "../data/portfolio";
import SectionShell from "./SectionShell.astro";

type Props = {
  id?: string;
  eyebrow?: string;
  heading?: string;
  items: ExperienceItem[];
};

const {
  id = "experience",
  eyebrow = "Experience",
  heading = "Professional experience and the work patterns behind it.",
  items,
} = Astro.props;
---

<SectionShell id={id} eyebrow={eyebrow} heading={heading}>
  <div class="timeline">
    {items.map((item) => (
      <article class="timeline-card glass-panel spotlight-panel">
        <div class="timeline-card__meta">
          <p>{item.company}</p>
          <span>{item.period}</span>
        </div>
        <h3>{item.role}</h3>
        <p>{item.summary}</p>
        <ul class="detail-list">
          {item.bullets.map((bullet) => (
            <li>{bullet}</li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</SectionShell>
