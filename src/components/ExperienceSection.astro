---
import type { WorkItem } from "../data/portfolio";
import SectionShell from "./SectionShell.astro";

type Props = {
  items: WorkItem[];
};

const { items } = Astro.props;
const currentItems = items.filter((item) => !item.earlier);
const earlierItems = items.filter((item) => item.earlier);
---

<SectionShell
  id="experience"
  eyebrow="Experience"
  heading="Work measured by what became more reliable, useful, or efficient."
  intro="The overview stays brief. Open a role for the implementation context and responsibilities behind it."
>
  <div class="experience-list">
    {
      currentItems.map((item) => (
        <article class="work-card work-card--experience">
          <div class="work-card__meta">
            <p>{item.organization}</p>
            <p>{item.period}</p>
          </div>
          <h3>{item.title}</h3>
          <p class="work-card__summary">{item.summary}</p>
          <ul class="highlight-list">
            {item.highlights.map((highlight) => (
              <li>{highlight}</li>
            ))}
          </ul>
          <div class="chip-list" aria-label="Technologies and focus areas">
            {item.skills.slice(0, 6).map((skill) => (
              <span>{skill}</span>
            ))}
          </div>
          <div class="work-card__actions">
            <a class="text-link" href={`/work/${item.slug}`}>
              Read the full {item.organization} role{" "}
              <span aria-hidden="true">→</span>
            </a>
          </div>
          <details class="inline-details">
            <summary>
              Explore {item.organization} responsibilities and impact
            </summary>
            <div class="inline-details__content">
              {item.sections.map((section) => (
                <section>
                  <h4>{section.heading}</h4>
                  {section.summary && <p>{section.summary}</p>}
                </section>
              ))}
            </div>
          </details>
        </article>
      ))
    }
  </div>

  {
    earlierItems.length > 0 && (
      <details class="earlier-work">
        <summary>Earlier experience</summary>
        <div class="earlier-work__content">
          {earlierItems.map((item) => (
            <article>
              <div class="work-card__meta">
                <p>{item.organization}</p>
                <p>{item.period}</p>
              </div>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <a class="text-link" href={`/work/${item.slug}`}>
                View role details <span aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      </details>
    )
  }
</SectionShell>
