---
import type { ExperienceItem } from "../data/portfolio";
import SectionShell from "./SectionShell.astro";

type Props = {
  id?: string;
  eyebrow?: string;
  heading?: string;
  stageLabel?: string;
  items: ExperienceItem[];
};

const {
  id = "experience",
  eyebrow = "Experience",
  heading = "Professional experience and the work patterns behind it.",
  stageLabel,
  items,
} = Astro.props;
---

<SectionShell id={id} eyebrow={eyebrow} heading={heading} stageLabel={stageLabel}>
  <div class="timeline">
    {items.map((item) => (
      <article class="timeline-card glass-panel spotlight-panel">
        <div class="timeline-card__meta">
          <p>{item.company}</p>
          <span>{item.period}</span>
        </div>
        <h3>{item.role}</h3>
        <p>{item.summary}</p>
        <ul class="detail-list">
          {item.bullets.map((bullet) => (
            <li>{bullet}</li>
          ))}
        </ul>
        {item.details && item.details.length > 0 && (
          <details class="story-disclosure">
            <summary>More about this role</summary>
            <ul class="detail-list">
              {item.details.map((detail) => (
                <li>{detail}</li>
              ))}
            </ul>
          </details>
        )}
      </article>
    ))}
  </div>
</SectionShell>
