---
import type { ExperienceItem } from "../data/portfolio";

type Props = {
  items: ExperienceItem[];
};

const { items } = Astro.props;
---

<section class="section-grid reveal" id="experience">
  <div class="section-heading">
    <p class="eyebrow">Experience</p>
    <h2>Professional experience and the work patterns behind it.</h2>
  </div>

  <div class="timeline">
    {items.map((item) => (
      <article class="timeline-card glass-panel spotlight-panel">
        <div class="timeline-card__meta">
          <p>{item.company}</p>
          <span>{item.period}</span>
        </div>
        <h3>{item.role}</h3>
        <p>{item.summary}</p>
        <ul class="detail-list">
          {item.bullets.map((bullet) => (
            <li>{bullet}</li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>
