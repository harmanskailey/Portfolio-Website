---
import type { FocusArea } from "../data/portfolio";
import SectionShell from "./SectionShell.astro";

type Props = {
  id?: string;
  eyebrow?: string;
  heading?: string;
  items: FocusArea[];
};

const {
  id = "about",
  eyebrow = "About",
  heading = "What I spend most of my time building and learning.",
  items,
} = Astro.props;
---

<SectionShell id={id} eyebrow={eyebrow} heading={heading}>
  <div class="feature-grid">
    {items.map((item) => (
      <article class="feature-card glass-panel spotlight-panel">
        <h3>{item.title}</h3>
        <p>{item.text}</p>
      </article>
    ))}
  </div>
</SectionShell>
