---
import type { ShowcaseItem } from "../data/portfolio";
import SectionShell from "./SectionShell.astro";

type Props = {
  id?: string;
  eyebrow?: string;
  heading?: string;
  items: ShowcaseItem[];
};

const {
  id = "showcase",
  eyebrow = "More",
  heading = "Additional pages for interests and work I want to build out over time.",
  items,
} = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<SectionShell id={id} eyebrow={eyebrow} heading={heading}>
  <div class="project-grid">
    {items.map((item) => (
      <a class="project-card glass-panel spotlight-panel showcase-link" href={`${basePath}/showcase/${item.slug}` || `/showcase/${item.slug}`}>
        <p class="project-card__category">{item.category}</p>
        <h3>{item.title}</h3>
        <p>{item.summary}</p>
        <div class="chip-row">
          {item.tags.map((tag) => (
            <span class="chip chip-soft">{tag}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</SectionShell>
